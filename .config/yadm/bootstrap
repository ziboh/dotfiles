#!/bin/bash
export ZSH_CACHE_DIR="$HOME/.cache/zsh"
cd "$HOME"
PYENV_PYTHON=3.10.9

sudo apt update
if ! command -v git >/dev/null 2>&1; then
    sudo apt install -y git
fi
if ! command -v curl >/dev/null 2>&1; then
    sudo apt install -y curl
fi
if ! command -v wget >/dev/null 2>&1; then
    sudo apt install -y wget
fi
if ! command -v zsh >/dev/null 2>&1; then
    sudo apt install -y zsh
    chsh -s $(which zsh)
fi
if ! command -v cargo >/dev/null 2>&1; then
    curl -sSf https://static.rust-lang.org/rustup.sh | shfi
    cargo install --git https://github.com/MordechaiHadad/bob.git
fi

if [ ! -s "$NVM_DIR/nvm.sh" ]; then
    export NVM_DIR="$HOME/.nvm" && (
        git clone https://github.com/nvm-sh/nvm.git "$NVM_DIR"
        cd "$NVM_DIR"
        git checkout `git describe --abbrev=0 --tags --match "v[0-9]*" $(git rev-list --tags --max-count=1)`
    ) && \. "$NVM_DIR/nvm.sh"
    cd $HOME
    nvm install node
fi

if [ ! -d "$HOME/.pyenv" ]; then
    sudo apt install -y liblzma-dev build-essential libreadline-dev libncursesw5-dev libssl-dev libsqlite3-dev tk-dev libgdbm-dev libc6-dev libbz2-dev libffi-dev zlib1g-dev
    git clone https://github.com/pyenv/pyenv.git ~/.pyenv
    pyenv install $PYENV_PYTHON
    pyenv global $PYENV_ROOT
fi

if [  -d "$HOME/.pyenv" ];then
    if [ ! -d "$PYENV_ROOT/plugins/pyenv-virtualenv" ]; then
        git clone https://github.com/pyenv/pyenv-virtualenv.git $(pyenv root)/plugins/pyenv-virtualenv
    fi
fi

if [ ! -d "$HOME/bin" ]; then
    mkdir $HOME/bin
fi

if [ -f "$HOME/bin/fzf" ]; then
    echo "$HOME/bin/fzf exists."
else
    # 从 Github API 获取最新的 fzf release 发布名称和版本号
    latest=$(curl -s https://api.github.com/repos/junegunn/fzf/releases/latest | grep -oP '"tag_name": "\K(.*)(?=")')

    # 构建最新的 fzf release 下载链接
    url="https://github.com/junegunn/fzf/releases/download/${latest}/fzf-${latest}-linux_amd64.tar.gz"
    wget $url --output fzf.tar.gz
    tar -zxvf fzf.tar.gz -C ~/bin
    rm -rf fzf.tar.gz
fi


if [ ! -f "/usr/local/bin/lazygit" ]; then
    LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
    curl -Lo lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
    tar xf lazygit.tar.gz lazygit
    sudo install lazygit /usr/local/bin
    rm -rf lazygit.tar.gz lazygit
fi

if ! command -v autojump >/dev/null 2>&1; then
    sudo apt install -y autojump
fi

zsh
node install -g neovim
pip install thefuck
pyenv virtualenv $PYENV_PYTHON pynvim
if [ ! -d "$ZSH_CACHE_DIR/thefuck" ]; then
    echo 'ZSH_CACHE_DIR'
    mkdir -p $ZSH_CACHE_DIR/thefuck
fi
yadm checkout HEAD .zshrc
echo "Init submodules"
yadm submodule update --recursive --init
yadm decrypt
